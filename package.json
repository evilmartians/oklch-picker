{
  "name": "oklch-picker",
  "private": true,
  "homepage": "https://oklch.com/",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "build": "vite build -m production",
    "clean": "rm -Rf ./dist/",
    "build:lch": "LCH=1 vite build -m production && ./lch.sh",
    "test:js": "oxlint",
    "test:css": "stylelint .",
    "test:build": "node --run build && size-limit && node --run build:lch",
    "test:unit": "bnt",
    "test": "FORCE_COLOR=1 pnpm run /^test:/"
  },
  "dependencies": {
    "@colordx/core": "^5.2.0",
    "@csstools/postcss-oklab-function": "^5.0.2",
    "@nanostores/persistent": "^1.3.3",
    "autoprefixer": "^10.4.27",
    "culori": "^4.0.2",
    "delaunator": "^5.1.0",
    "jstransformer-markdown-it": "^3.0.0",
    "lightningcss": "^1.32.0",
    "nanodelay": "^2.0.2",
    "nanostores": "^1.2.0",
    "plausible-client": "^2.0.0",
    "postcss": "^8.5.8",
    "postcss-media-minmax": "^5.0.0",
    "postcss-mixins": "^12.1.2",
    "postcss-nesting": "^14.0.0",
    "postcss-opacity-percentage": "^3.0.0",
    "three": "~0.183.2",
    "vite": "^8.0.3",
    "vite-plugin-pug-transformer": "^1.0.8"
  },
  "devDependencies": {
    "@logux/oxc-configs": "^0.2.2",
    "@logux/stylelint-config": "^0.22.0",
    "@size-limit/file": "^12.0.1",
    "@types/culori": "^4.0.1",
    "@types/delaunator": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/three": "^0.183.1",
    "actions-up": "^1.12.0",
    "better-node-test": "^0.8.4",
    "happy-dom": "^20.8.9",
    "multiocular": "^0.8.2",
    "nano-staged": "^0.9.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.1",
    "stylelint": "^17.6.0",
    "svgo": "^4.0.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
